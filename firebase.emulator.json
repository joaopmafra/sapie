{
  "hosting": {
    "public": "packages/web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "packages/api/dist"
    }
  ],
  "emulators": {
    "singleProjectMode": true,
    "hub": {
      "host": "0.0.0.0",
      "port": 4400
    },
    "logging": {
      "host": "0.0.0.0",
      "port": 4500
    },
    "firestore": {
      "host": "0.0.0.0",
      "port": 8080,
      "websocketPort": 9150
    },
    "auth": {
      "host": "0.0.0.0",
      "port": 9099
    },
    "hosting": {
      "host": "0.0.0.0",
      "port": 5000
    },
    "functions": {
      "host": "0.0.0.0",
      "port": 5001
    },
    "storage": {
      "host": "0.0.0.0",
      "port": 9210
    },    
    "ui": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 4000
    }
  }
}
