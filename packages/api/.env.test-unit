# Local Development Environment Variables

# Current environment identifier
CURRENT_ENV=test-unit

# Firebase emulator setup
FIREBASE_USE_EMULATOR=true
FIREBASE_AUTH_EMULATOR_HOST=localhost:9199
FIRESTORE_EMULATOR_HOST=localhost:8181

# When running on Firebase or emulator, the GCLOUD_PROJECT is set automatically. As we're not, we need to set it
# mannually to initialize the Firebase Admin SDK
GCLOUD_PROJECT=demo-test-unit
