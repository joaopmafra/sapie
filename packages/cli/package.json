{
  "name": "@sapie/cli",
  "version": "0.0.1",
  "description": "Sapie Sync CLI — synchronize content between Sapie backend and local filesystem",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "sapie": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "test": "NODE_OPTIONS='--disable-warning=DEP0040' jest",
    "test:watch": "NODE_OPTIONS='--disable-warning=DEP0040' jest --watch",
    "verify:types": "tsc -p tsconfig.json --noEmit",
    "verify:all": "pnpm verify:types && pnpm lint:check && pnpm format:check"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/yargs": "^17.0.33",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "16.2.0",
    "jest": "^29.7.0",
    "nock": "^14.0.1",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.34.0"
  }
}
